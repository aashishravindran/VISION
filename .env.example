# Required
OPENAI_API_KEY=sk-...

# Tiingo — prices, market caps, fundamentals (Dow 30 only on free tier).
# Free at https://www.tiingo.com/account/api/token (~500 req/day; we cache hard).
TIINGO_API_KEY=

# Financial Modeling Prep — server-side stock screener (HUGE win vs per-ticker
# Tiingo loops). Optional; if set, screener uses FMP first and falls back to
# Tiingo when FMP rate-limits. Free key (250 req/day) at:
# https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# Optional model overrides
#   VISION_MODEL     — orchestrator (default: gpt-5)
#   VISION_SUB_MODEL — specialists  (default: gpt-5-mini, much faster)
# VISION_MODEL=gpt-4o
# VISION_SUB_MODEL=gpt-5-mini
